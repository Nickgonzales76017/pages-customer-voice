#!/usr/bin/env bash
# ─── Bonfyre Pages App Hook ──────────────────────────────────────────────────
set -euo pipefail

BONFYRE_BIN="${BONFYRE_BIN:-$HOME/.local/bin}"
export PATH="$BONFYRE_BIN:$PATH"

log() { printf "\033[0;33m[bonfyre]\033[0m %s\n" "$1"; }
err() { printf "\033[0;31m[bonfyre]\033[0m %s\n" "$1" >&2; }

require_bin() {
  for b in "$@"; do
    command -v "$b" >/dev/null 2>&1 || { err "Missing: $b (run 'make install' in bonfyre-oss)"; return 1; }
  done
}

BINS=(bonfyre-media-prep bonfyre-transcribe bonfyre-tone bonfyre-tag bonfyre-embed bonfyre-vec bonfyre-brief bonfyre-emit)
require_bin "${BINS[@]}" || exit 0

CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD -- input/ 2>/dev/null || true)
[ -z "$CHANGED" ] && exit 0

log "Customer Voice: processing $(echo "$CHANGED" | wc -l | tr -d ' ') interview(s)…"

for f in $CHANGED; do
  [ -f "$f" ] || continue
  base=$(basename "$f" | sed 's/\.[^.]*$//')
  ext="${f##*.}"

  case "$ext" in
    wav|mp3|m4a|ogg|flac|webm)
      log "[$base] transcribe → tone → tag → embed → vec → brief"
      bonfyre-media-prep "$f" --out "artifacts/${base}.prep.json"
      bonfyre-transcribe "artifacts/${base}.prep.json" --out "artifacts/${base}.transcript.json"
      bonfyre-tone "artifacts/${base}.transcript.json" --out "artifacts/${base}.tone.json"
      bonfyre-tag "artifacts/${base}.transcript.json" --out "artifacts/${base}.tags.json"
      bonfyre-embed "artifacts/${base}.tags.json" --out "artifacts/${base}.embed.json"
      bonfyre-vec "artifacts/${base}.embed.json" --insert-db "artifacts/voice.db"
      bonfyre-brief "artifacts/${base}.transcript.json" --out "artifacts/${base}.brief.json"
      ;;
    *) log "[$base] skipping: $ext" ;;
  esac
done

log "Generating research dashboard…"
bonfyre-emit artifacts/ --out site/ --format html
log "Dashboard updated with $(find artifacts/ -name '*.tone.json' | wc -l | tr -d ' ') sentiment profiles."
